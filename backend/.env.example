OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# Preferred ytmusicapi OAuth setup. Keep real values in backend/private/.env or your shell, never in Git.
YTMUSIC_AUTH_FILE=backend/private/oauth.json
YTMUSIC_BROWSER_AUTH_FILE=backend/private/browser.json
YTMUSIC_OAUTH_CLIENT_ID=
YTMUSIC_OAUTH_CLIENT_SECRET=

# Optional Spotify login. Keep real values in backend/private/.env or your shell, never in Git.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/spotify/callback
