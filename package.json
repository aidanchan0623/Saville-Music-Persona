{
  "name": "saville-music-persona",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first YouTube Music taste analysis dashboard powered by ytmusicapi and Ollama.",
  "scripts": {
    "setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup_windows.ps1",
    "dev": "powershell -ExecutionPolicy Bypass -File ./scripts/run_dev.ps1",
    "frontend:dev": "npm.cmd --prefix frontend run dev",
    "frontend:build": "npm.cmd --prefix frontend run build",
    "frontend:lint": "npm.cmd --prefix frontend run lint",
    "backend:test": "python -m pytest backend/tests",
    "backend:dev": "python -m uvicorn app.main:app --app-dir backend --reload --host 127.0.0.1 --port 8000"
  },
  "engines": {
    "node": ">=20"
  }
}

